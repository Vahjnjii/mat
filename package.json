{
  "name": "react-example",
  "version": "1.0.1",
  "comment": "Added sidebar improvements, chat renaming, and fixed GitHub Pages base path.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
